import React, { useState, useEffect, useMemo } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getFirestore, 
  collection, 
  addDoc, 
  onSnapshot, 
  doc, 
  updateDoc, 
  deleteDoc,
  query
} from 'firebase/firestore';
import { 
  getAuth, 
  signInAnonymously, 
  signInWithCustomToken, 
  onAuthStateChanged 
} from 'firebase/auth';
import { 
  Users, 
  Package, 
  DollarSign, 
  LayoutDashboard, 
  Plus, 
  Search, 
  Trash2, 
  Calendar, 
  ShieldCheck, 
  MapPin,
  Menu,
  X,
  TrendingUp,
  TrendingDown,
  Sun,
  ChevronRight,
  ArrowUpRight,
  Zap,
  Phone,
  ArrowDownRight
} from 'lucide-react';

// --- CONFIGURACIÓN FIREBASE (Globales del Entorno) ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'solar-manager-v2';

const App = () => {
  const [user, setUser] = useState(null);
  const [activeTab, setActiveTab] = useState('dashboard');
  
  // Estados de Datos
  const [clients, setClients] = useState([]);
  const [inventory, setInventory] = useState([]);
  const [finances, setFinances] = useState([]);
  const [loading, setLoading] = useState(true);
  const [searchTerm, setSearchTerm] = useState('');

  // 1. Autenticación (Regla 3)
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) {
        console.error("Auth Error:", error);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  // 2. Carga de Datos (Regla 1 y 2)
  useEffect(() => {
    if (!user) return;

    const clientsRef = collection(db, 'artifacts', appId, 'public', 'data', 'clients');
    const inventoryRef = collection(db, 'artifacts', appId, 'public', 'data', 'inventory');
    const financeRef = collection(db, 'artifacts', appId, 'public', 'data', 'finances');

    const unsubClients = onSnapshot(clientsRef, (snapshot) => {
      setClients(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
      setLoading(false);
    }, (err) => console.error("Error clientes:", err));

    const unsubInventory = onSnapshot(inventoryRef, (snapshot) => {
      setInventory(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
    }, (err) => console.error("Error inventario:", err));

    const unsubFinance = onSnapshot(financeRef, (snapshot) => {
      setFinances(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
    }, (err) => console.error("Error finanzas:", err));

    return () => { unsubClients(); unsubInventory(); unsubFinance(); };
  }, [user]);

  // Acciones CRUD
  const deleteItem = async (col, id) => {
    if(window.confirm('¿Estás seguro de eliminar este registro?')) {
      await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', col, id));
    }
  };

  const stats = useMemo(() => {
    const income = finances.filter(f => f.type === 'income').reduce((acc, curr) => acc + curr.amount, 0);
    const expense = finances.filter(f => f.type === 'expense').reduce((acc, curr) => acc + curr.amount, 0);
    return { 
      balance: income - expense, 
      clientsCount: clients.length, 
      stock: inventory.reduce((acc, curr) => acc + (curr.stock || 0), 0)
    };
  }, [finances, clients, inventory]);

  const filteredClients = clients.filter(c => 
    c.name?.toLowerCase().includes(searchTerm.toLowerCase()) || 
    c.address?.toLowerCase().includes(searchTerm.toLowerCase())
  );

  // Componentes Reutilizables de UI
  const NavItem = ({ id, icon: Icon, label }) => {
    const isActive = activeTab === id;
    return (
      <button
        onClick={() => setActiveTab(id)}
        className={`flex flex-col md:flex-row items-center justify-center space-y-1 md:space-y-0 md:space-x-3 px-3 py-2 md:px-5 md:py-2.5 rounded-2xl transition-all duration-300 ${
          isActive 
            ? 'bg-amber-500 text-white shadow-lg shadow-amber-200 scale-105' 
            : 'text-slate-400 hover:text-slate-600 hover:bg-slate-100'
        }`}
      >
        <Icon size={isActive ? 22 : 20} strokeWidth={isActive ? 2.5 : 2} />
        <span className={`text-[10px] md:text-sm font-bold tracking-tight ${isActive ? 'block' : 'hidden md:block'}`}>{label}</span>
      </button>
    );
  };

  const SectionHeader = ({ title, subtitle, icon: Icon, color }) => (
    <div className={`relative overflow-hidden rounded-[2rem] p-6 md:p-10 mb-6 md:mb-10 text-white shadow-xl ${color}`}>
      <div className="relative z-10">
        <div className="flex items-center space-x-3 mb-3">
          <div className="bg-white/20 p-2.5 rounded-xl backdrop-blur-md">
            <Icon size={24} />
          </div>
          <span className="text-[10px] md:text-xs font-black uppercase tracking-[0.2em] opacity-80">Solar Manager Pro</span>
        </div>
        <h2 className="text-2xl md:text-5xl font-black mb-3 leading-tight">{title}</h2>
        <p className="text-white/80 max-w-lg font-medium text-sm md:text-base leading-relaxed">{subtitle}</p>
      </div>
      <div className="absolute top-[-20%] right-[-10%] opacity-10 pointer-events-none">
        <Icon size={300} />
      </div>
    </div>
  );

  if (!user) return (
    <div className="h-screen flex items-center justify-center bg-white">
      <div className="flex flex-col items-center gap-4">
        <Sun className="animate-spin text-amber-500" size={48} />
        <p className="text-slate-400 font-bold animate-pulse uppercase tracking-widest text-xs">Conectando...</p>
      </div>
    </div>
  );

  return (
    <div className="min-h-screen bg-slate-50 font-sans text-slate-900 selection:bg-amber-100 selection:text-amber-900">
      
      {/* NAVEGACIÓN SUPERIOR (Desktop/Tablet) */}
      <nav className="fixed top-0 left-0 right-0 h-20 bg-white/80 backdrop-blur-xl border-b border-slate-100 z-50 hidden md:flex items-center justify-between px-10">
        <div className="flex items-center space-x-3">
          <div className="bg-amber-500 p-2 rounded-xl text-white shadow-lg shadow-amber-200">
            <Sun size={24} strokeWidth={2.5} />
          </div>
          <span className="text-xl font-black tracking-tighter text-slate-800">
            SOLAR<span className="text-amber-500">PRO</span>
          </span>
        </div>
        
        <div className="flex space-x-2 bg-slate-100/60 p-1.5 rounded-[1.5rem]">
          <NavItem id="dashboard" icon={LayoutDashboard} label="Panel" />
          <NavItem id="clients" icon={Users} label="Clientes" />
          <NavItem id="inventory" icon={Package} label="Stock" />
          <NavItem id="finances" icon={DollarSign} label="Caja" />
        </div>

        <div className="flex items-center space-x-6">
          <div className="relative group">
            <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-amber-500 transition-colors" size={18} />
            <input 
              type="text" 
              placeholder="Buscar..." 
              className="pl-10 pr-4 py-2.5 bg-slate-100/80 rounded-2xl text-sm outline-none focus:ring-4 focus:ring-amber-500/10 focus:bg-white transition-all w-48 lg:w-64 border border-transparent focus:border-amber-200"
              value={searchTerm}
              onChange={(e) => setSearchTerm(e.target.value)}
            />
          </div>
          <div className="h-11 w-11 rounded-2xl bg-gradient-to-tr from-amber-400 to-orange-500 flex items-center justify-center text-white font-black shadow-lg shadow-orange-100 ring-2 ring-white">JD</div>
        </div>
      </nav>

      {/* NAVEGACIÓN INFERIOR (Móvil) */}
      <nav className="fixed bottom-6 left-1/2 -translate-x-1/2 w-[92%] max-w-lg bg-white/90 backdrop-blur-2xl border border-white/40 shadow-2xl rounded-[2.5rem] z-50 flex items-center justify-around p-3 md:hidden">
        <NavItem id="dashboard" icon={LayoutDashboard} label="Inicio" />
        <NavItem id="clients" icon={Users} label="Clientes" />
        <NavItem id="inventory" icon={Package} label="Stock" />
        <NavItem id="finances" icon={DollarSign} label="Dinero" />
      </nav>

      {/* CONTENIDO PRINCIPAL - Responsive Padding */}
      <main className="max-w-7xl mx-auto px-4 py-6 md:px-10 md:pt-28 pb-32 md:pb-12">
        
        {/* VISTA: PANEL DE CONTROL */}
        {activeTab === 'dashboard' && (
          <div className="animate-in fade-in slide-in-from-bottom-6 duration-700">
            <SectionHeader 
              title="Resumen General"
              subtitle="Control total de tu negocio de energía solar desde la palma de tu mano."
              icon={Sun}
              color="bg-gradient-to-br from-amber-400 to-orange-600"
            />
            
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8 mb-8 md:mb-12">
              <div className="bg-white p-6 md:p-8 rounded-[2.5rem] shadow-sm border border-slate-100 hover:shadow-2xl hover:shadow-emerald-100 transition-all group overflow-hidden relative">
                <div className="flex justify-between items-start mb-6">
                  <div className="p-4 bg-emerald-50 text-emerald-600 rounded-2xl group-hover:bg-emerald-500 group-hover:text-white transition-all duration-500">
                    <TrendingUp size={28} />
                  </div>
                  <div className="flex flex-col items-end">
                    <span className="text-[10px] font-black text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-lg">ACTIVO</span>
                  </div>
                </div>
                <p className="text-slate-400 font-bold text-xs uppercase tracking-[0.15em] mb-1">Balance Total</p>
                <h3 className="text-3xl md:text-5xl font-black text-slate-800 tracking-tight">${stats.balance.toLocaleString('es-MX')}</h3>
                <div className="absolute -bottom-4 -right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                  <DollarSign size={120} />
                </div>
              </div>

              <div className="bg-white p-6 md:p-8 rounded-[2.5rem] shadow-sm border border-slate-100 hover:shadow-2xl hover:shadow-blue-100 transition-all group overflow-hidden relative">
                <div className="flex justify-between items-start mb-6">
                  <div className="p-4 bg-blue-50 text-blue-600 rounded-2xl group-hover:bg-blue-500 group-hover:text-white transition-all duration-500">
                    <Users size={28} />
                  </div>
                </div>
                <p className="text-slate-400 font-bold text-xs uppercase tracking-[0.15em] mb-1">Cartera de Clientes</p>
                <h3 className="text-3xl md:text-5xl font-black text-slate-800 tracking-tight">{stats.clientsCount}</h3>
                <div className="absolute -bottom-4 -right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                  <Users size={120} />
                </div>
              </div>

              <div className="bg-white p-6 md:p-8 rounded-[2.5rem] shadow-sm border border-slate-100 hover:shadow-2xl hover:shadow-orange-100 transition-all group overflow-hidden relative sm:col-span-2 lg:col-span-1">
                <div className="flex justify-between items-start mb-6">
                  <div className="p-4 bg-orange-50 text-orange-600 rounded-2xl group-hover:bg-orange-500 group-hover:text-white transition-all duration-500">
                    <Package size={28} />
                  </div>
                </div>
                <p className="text-slate-400 font-bold text-xs uppercase tracking-[0.15em] mb-1">Unidades en Almacén</p>
                <h3 className="text-3xl md:text-5xl font-black text-slate-800 tracking-tight">{stats.stock}</h3>
                <div className="absolute -bottom-4 -right-4 opacity-5 group-hover:opacity-10 transition-opacity">
                  <Zap size={120} />
                </div>
              </div>
            </div>

            <h3 className="text-lg md:text-xl font-black text-slate-800 mb-6 px-2 flex items-center gap-3">
              <Zap size={20} className="text-amber-500" /> Accesos Rápidos
            </h3>
            
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              {[
                { label: 'Nuevo Cliente', icon: Plus, tab: 'clients', color: 'bg-blue-50 text-blue-600' },
                { label: 'Registrar Venta', icon: DollarSign, tab: 'finances', color: 'bg-emerald-50 text-emerald-600' },
                { label: 'Ver Inventario', icon: Search, tab: 'inventory', color: 'bg-slate-100 text-slate-600' },
                { label: 'Estado Caja', icon: TrendingUp, tab: 'finances', color: 'bg-amber-50 text-amber-600' },
              ].map((act, i) => (
                <button 
                  key={i} 
                  onClick={() => setActiveTab(act.tab)}
                  className="bg-white p-5 md:p-8 rounded-[2.5rem] shadow-sm border border-slate-100 flex flex-col items-center justify-center space-y-4 hover:scale-[1.03] active:scale-95 transition-all hover:shadow-xl group"
                >
                  <div className={`${act.color} p-4 rounded-2xl group-hover:scale-110 transition-transform`}>
                    <act.icon size={26} strokeWidth={2.5} />
                  </div>
                  <span className="font-black text-[10px] md:text-sm uppercase tracking-tight text-slate-700">{act.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        {/* VISTA: CLIENTES */}
        {activeTab === 'clients' && (
          <div className="animate-in fade-in slide-in-from-right-8 duration-500">
            <SectionHeader 
              title="Gestión de Clientes"
              subtitle="Administra la base de datos de tus instalaciones solares y seguimientos."
              icon={Users}
              color="bg-gradient-to-br from-blue-500 to-indigo-700"
            />

            <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12">
              <div className="lg:col-span-4">
                <div className="bg-white p-6 md:p-10 rounded-[2.5rem] shadow-xl shadow-slate-200/40 sticky top-24 border border-slate-50">
                  <h3 className="text-xl font-black mb-8 flex items-center gap-3 text-slate-800">
                    <Plus className="text-blue-500" size={24} /> Registrar Instalación
                  </h3>
                  <form onSubmit={async (e) => {
                    e.preventDefault();
                    const fd = new FormData(e.target);
                    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'clients'), {
                      name: fd.get('name'), 
                      phone: fd.get('phone'),
                      address: fd.get('address'), 
                      warranty: fd.get('warranty'), 
                      date: fd.get('date'), 
                      panels: fd.get('panels'), 
                      createdAt: new Date().toISOString()
                    });
                    e.target.reset();
                  }} className="space-y-6">
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Nombre Completo</label>
                      <input name="name" required className="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl outline-none transition-all font-medium" placeholder="Ej: Roberto Sánchez" />
                    </div>
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Teléfono</label>
                      <input name="phone" type="tel" required className="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl outline-none transition-all font-medium" placeholder="+52 00 0000 0000" />
                    </div>
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Ubicación</label>
                      <input name="address" required className="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl outline-none transition-all font-medium" placeholder="Calle Sol #100" />
                    </div>
                    <div className="grid grid-cols-2 gap-4">
                      <div className="space-y-2">
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Garantía</label>
                        <input name="warranty" required className="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-sm" placeholder="10 años" />
                      </div>
                      <div className="space-y-2">
                        <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Paneles</label>
                        <input name="panels" type="number" required className="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl outline-none transition-all font-medium text-sm" placeholder="12" />
                      </div>
                    </div>
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Fecha Instalación</label>
                      <input name="date" type="date" required className="w-full p-4 bg-slate-50 border-2 border-transparent focus:border-blue-500 focus:bg-white rounded-2xl outline-none transition-all font-medium" />
                    </div>
                    <button type="submit" className="w-full py-5 bg-blue-600 text-white font-black rounded-2xl shadow-xl shadow-blue-200 hover:bg-blue-700 hover:shadow-2xl transition-all active:scale-95 text-sm uppercase tracking-widest">Guardar Registro</button>
                  </form>
                </div>
              </div>

              <div className="lg:col-span-8 space-y-4">
                {filteredClients.map(c => (
                  <div key={c.id} className="bg-white p-5 md:p-8 rounded-[2.5rem] border border-slate-100 flex flex-col md:flex-row md:items-center justify-between group hover:shadow-2xl hover:border-blue-100 transition-all duration-300">
                    <div className="flex items-center space-x-6">
                      <div className="h-14 w-14 md:h-20 md:w-20 rounded-3xl bg-blue-50 text-blue-600 flex items-center justify-center font-black text-xl md:text-3xl shadow-sm">
                        {c.name?.charAt(0)}
                      </div>
                      <div className="space-y-1">
                        <h4 className="font-black text-slate-800 text-lg md:text-2xl leading-none">{c.name}</h4>
                        <div className="flex flex-col md:flex-row md:items-center gap-1 md:gap-4 text-xs md:text-sm text-slate-400 font-bold mt-2">
                          <span className="flex items-center gap-2"><Phone size={14} className="text-blue-400"/> {c.phone}</span>
                          <span className="flex items-center gap-2"><MapPin size={14}/> {c.address}</span>
                        </div>
                      </div>
                    </div>
                    <div className="flex items-center justify-between md:justify-end gap-4 md:gap-10 mt-6 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-slate-50">
                      <div className="text-left md:text-right">
                        <p className="text-[10px] font-black text-slate-300 uppercase tracking-widest mb-1">Garantía Activa</p>
                        <div className="flex items-center gap-2 text-emerald-600 font-black text-sm md:text-lg">
                          <ShieldCheck size={18} /> {c.warranty}
                        </div>
                      </div>
                      <button onClick={() => deleteItem('clients', c.id)} className="p-3.5 text-slate-300 hover:text-rose-500 hover:bg-rose-50 rounded-2xl transition-all active:scale-90">
                        <Trash2 size={22} />
                      </button>
                    </div>
                  </div>
                ))}
                {filteredClients.length === 0 && (
                  <div className="py-32 flex flex-col items-center justify-center bg-white rounded-[3rem] border-2 border-dashed border-slate-100 text-slate-300 space-y-4">
                    <Users size={64} strokeWidth={1} />
                    <p className="font-black uppercase tracking-widest text-sm">No se encontraron clientes</p>
                  </div>
                )}
              </div>
            </div>
          </div>
        )}

        {/* VISTA: ALMACÉN */}
        {activeTab === 'inventory' && (
          <div className="animate-in fade-in slide-in-from-right-8 duration-500">
            <SectionHeader 
              title="Inventario Solar"
              subtitle="Control riguroso de componentes: paneles, inversores, baterías y estructuras."
              icon={Package}
              color="bg-gradient-to-br from-slate-700 to-slate-900"
            />
            
            <div className="bg-white p-6 md:p-10 rounded-[3rem] shadow-sm border border-slate-100 mb-10">
              <h3 className="text-lg font-black mb-6 text-slate-800 flex items-center gap-2">
                <Plus size={20} className="text-amber-500" /> Añadir Material
              </h3>
              <form onSubmit={async (e) => {
                e.preventDefault();
                const fd = new FormData(e.target);
                await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'inventory'), {
                  name: fd.get('name'), 
                  stock: parseInt(fd.get('stock')), 
                  price: parseFloat(fd.get('price')),
                  category: fd.get('category')
                });
                e.target.reset();
              }} className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-end">
                <div className="space-y-2 lg:col-span-1">
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Producto</label>
                  <input name="name" required className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none focus:ring-4 focus:ring-slate-100 font-medium" placeholder="Panel Tier 1" />
                </div>
                <div className="space-y-2">
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Stock Inicial</label>
                  <input name="stock" type="number" required className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none focus:ring-4 focus:ring-slate-100 font-medium" placeholder="0" />
                </div>
                <div className="space-y-2">
                  <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Costo p/u</label>
                  <input name="price" type="number" step="0.01" required className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none focus:ring-4 focus:ring-slate-100 font-medium" placeholder="$0.00" />
                </div>
                <button type="submit" className="w-full py-4 bg-slate-800 text-white font-black rounded-2xl hover:bg-black transition-all shadow-xl shadow-slate-200">Registrar</button>
              </form>
            </div>

            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
              {inventory.map(item => (
                <div key={item.id} className="bg-white p-8 rounded-[2.5rem] border border-slate-100 relative group hover:shadow-2xl hover:-translate-y-2 transition-all duration-300">
                  <div className={`absolute top-6 right-6 h-3 w-3 rounded-full ${item.stock < 5 ? 'bg-rose-500 animate-pulse' : 'bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.5)]'}`}></div>
                  
                  <div className="p-4 bg-slate-50 rounded-2xl w-fit mb-6 text-slate-600 group-hover:bg-amber-500 group-hover:text-white transition-colors duration-500">
                    <Package size={24} />
                  </div>

                  <h4 className="font-black text-slate-800 text-xl mb-1 truncate">{item.name}</h4>
                  <p className="text-sm text-slate-400 font-bold uppercase tracking-tight mb-6">Unid: ${item.price?.toLocaleString() || '0'}</p>
                  
                  <div className="flex items-end justify-between border-t border-slate-50 pt-6">
                    <div>
                      <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Disponibilidad</p>
                      <p className="text-3xl font-black text-slate-800">{item.stock} <span className="text-xs font-medium text-slate-400 uppercase">unid</span></p>
                    </div>
                    <button onClick={() => deleteItem('inventory', item.id)} className="p-3 text-slate-200 hover:text-rose-500 transition-colors bg-slate-50 rounded-xl">
                      <Trash2 size={20} />
                    </button>
                  </div>

                  <div className="mt-6 w-full bg-slate-100 h-2.5 rounded-full overflow-hidden">
                    <div 
                      className={`h-full rounded-full transition-all duration-1000 ${item.stock < 5 ? 'bg-rose-500' : 'bg-emerald-500'}`} 
                      style={{ width: `${Math.min((item.stock / 20) * 100, 100)}%` }}
                    ></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* VISTA: CAJA/FINANZAS */}
        {activeTab === 'finances' && (
          <div className="animate-in fade-in slide-in-from-right-8 duration-500">
            <SectionHeader 
              title="Contabilidad"
              subtitle="Mantén el flujo de caja saludable. Registra ventas de proyectos y gastos operativos."
              icon={DollarSign}
              color="bg-gradient-to-br from-emerald-500 to-teal-800"
            />

            <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12">
              <div className="lg:col-span-4">
                <div className="bg-white p-8 md:p-10 rounded-[3rem] shadow-xl shadow-emerald-900/5 sticky top-24 border border-slate-50">
                  <h3 className="text-xl font-black mb-8 text-slate-800">Nueva Operación</h3>
                  <form onSubmit={async (e) => {
                    e.preventDefault();
                    const fd = new FormData(e.target);
                    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'finances'), {
                      description: fd.get('description'), 
                      amount: parseFloat(fd.get('amount')),
                      type: fd.get('type'), 
                      date: fd.get('date'), 
                      createdAt: new Date().toISOString()
                    });
                    e.target.reset();
                  }} className="space-y-6">
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Concepto</label>
                      <input name="description" required className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none focus:ring-4 focus:ring-emerald-50 font-medium" placeholder="Ej: Venta de Inversor 5kW" />
                    </div>
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Monto ($)</label>
                      <input name="amount" type="number" step="0.01" required className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none focus:ring-4 focus:ring-emerald-50 font-black text-emerald-700 text-lg" placeholder="0.00" />
                    </div>
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Tipo de Movimiento</label>
                      <select name="type" className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none font-bold text-slate-600 appearance-none cursor-pointer focus:ring-4 focus:ring-emerald-50">
                        <option value="income">Ingreso (+)</option>
                        <option value="expense">Gasto (-)</option>
                      </select>
                    </div>
                    <div className="space-y-2">
                      <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-2">Fecha Contable</label>
                      <input name="date" type="date" required className="w-full p-4 bg-slate-50 border-none rounded-2xl outline-none focus:ring-4 focus:ring-emerald-50 font-medium" />
                    </div>
                    <button type="submit" className="w-full py-5 bg-emerald-600 text-white font-black rounded-2xl shadow-xl shadow-emerald-100 hover:bg-emerald-700 hover:shadow-2xl transition-all active:scale-95 uppercase tracking-widest text-sm">Registrar en Caja</button>
                  </form>
                </div>
              </div>

              <div className="lg:col-span-8">
                <div className="bg-white rounded-[3rem] shadow-sm border border-slate-100 overflow-hidden">
                  <div className="p-8 border-b border-slate-50 bg-slate-50/40 flex justify-between items-center">
                    <h3 className="font-black text-slate-800 uppercase tracking-[0.2em] text-xs">Historial Contable</h3>
                  </div>
                  <div className="max-h-[700px] overflow-y-auto p-4 md:p-6 space-y-3">
                    {finances.sort((a,b) => new Date(b.date) - new Date(a.date)).map(f => (
                      <div key={f.id} className="flex items-center justify-between p-5 hover:bg-slate-50 rounded-[2rem] transition-all group">
                        <div className="flex items-center gap-5">
                          <div className={`p-4 rounded-2xl shadow-sm ${f.type === 'income' ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600'}`}>
                            {f.type === 'income' ? <ArrowUpRight size={22} strokeWidth={3} /> : <ArrowDownRight size={22} strokeWidth={3} />}
                          </div>
                          <div>
                            <p className="font-black text-slate-800 text-lg leading-none mb-1">{f.description}</p>
                            <p className="text-[10px] text-slate-400 font-black uppercase tracking-widest">{f.date}</p>
                          </div>
                        </div>
                        <div className="flex items-center gap-6">
                          <span className={`text-xl font-black tabular-nums ${f.type === 'income' ? 'text-emerald-600' : 'text-rose-500'}`}>
                            {f.type === 'income' ? '+' : '-'}${f.amount.toLocaleString()}
                          </span>
                          <button onClick={() => deleteItem('finances', f.id)} className="opacity-0 group-hover:opacity-100 p-3 text-slate-300 hover:text-rose-500 transition-all bg-white shadow-sm rounded-xl border border-slate-100">
                            <Trash2 size={18} />
                          </button>
                        </div>
                      </div>
                    ))}
                    {finances.length === 0 && (
                      <div className="py-40 text-center text-slate-300">
                        <DollarSign size={48} className="mx-auto mb-4 opacity-20" />
                        <p className="font-black uppercase tracking-widest text-sm">Sin movimientos registrados</p>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}

      </main>
    </div>
  );
};

export default App;
